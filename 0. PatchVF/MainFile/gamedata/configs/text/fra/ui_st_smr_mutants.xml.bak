<string_table>
	<string id="ui_mcm_menu_smr_mutants">
		<text>Mutant</text>
	</string>
    <string id="ui_mcm_smr_mutants_types_title">
		<text>Types de mutants</text>
	</string>
	<string id="ui_mcm_SMR_smr_mutants_squad_size">
		<text>Taille des hords de Mutants</text>
	</string>
	<string id="ui_mcm_SMR_smr_mutants_squad_size_variance">
		<text>Variation de taille des escouades</text>
	</string>
	<string id="ui_mcm_SMR_smr_mutants_squad_size_variance_desc">
		<text>Plus ce paramètre est élevé, plus la taille des meutes de mutants sera aléatoire.</text>
	</string>
	<string id="ui_mcm_SMR_smr_mutants_random_mutants">
		<text>Escouades aléatoires de mutants</text>
	</string>
	<string id="ui_mcm_SMR_smr_mutants_random_mutants_desc">
		<text>Remplace les meutes de mutants par d'autres meutes de mutants choisies aléatoirement. Cela signifie que vous pourriez rencontrer certains mutants dans des zones où vous ne les attendiez pas auparavant.</text>
	</string>
	<string id="ui_mcm_SMR_smr_mutants_random_mutants_chance">
		<text>Chance d'escouades aléatoires de mutants</text>
	</string>
	<string id="ui_mcm_SMR_smr_mutants_balanced_mutants">
		<text>Apparition équilibrée de Mutants</text>
	</string>
	<string id="ui_mcm_SMR_smr_mutants_balanced_mutants_desc">
		<text>Moins de mutants puissants dans les zones extérieures et inversement.</text>
	</string>
	<string id="ui_mcm_SMR_smr_mutants_types_info">
		<text>Activer ou désactiver les types de mutants. Les mutants désactivés n'apparaîtront pas dans la Zone</text>
	</string>
	<string id="ui_mcm_SMR_smr_mutants_types_replace_squads">
		<text>Remplacer les escouades supprimées</text>
	</string>
	<string id="ui_mcm_SMR_smr_mutants_types_replace_squads_desc">
		<text>Remplace les meutes composées uniquement de mutants désactivés par des meutes composées de mutants activés.</text>
	</string>
