<?xml version="1.0" encoding="UTF-8"?>

<string_table>

	<!-- Button -->
	<string id="ui_mcm_ssfx_module_ao">
		<text>Occlusion ambiante</text>
	</string>

	<!-- SSR Settings -->
	<string id="ui_mcm_ssfx_module_ao_title">
		<text>Paramètres d'occlusion ambiante</text>
	</string>

	<string id="ui_mcm_ssfx_module_ao_quality_mcm">
		<text>Qualité</text>
	</string>

	<string id="ui_mcm_ssfx_module_ao_quality_mcm_desc">
		<text>[ REDÉMARRAGE REQUIS ] Nombre d'échantillons utilisés pour le rendu de l'occlusion ambiante. Le réglage Très Élevé peut fortement impacter vos performances. [ 2, 4, 8 ]</text>
	</string>

	<string id="ui_mcm_ssfx_module_ao_res_mcm">
		<text>Résolution</text>
	</string>

	<string id="ui_mcm_ssfx_module_ao_res_mcm_desc">
		<text>Résolution du rendu de l'occlusion ambiante.</text>
	</string>

	<string id="ui_mcm_ssfx_module_ao_distance_mcm">
		<text>Distance maximale</text>
	</string>

	<string id="ui_mcm_ssfx_module_ao_distance_mcm_desc">
		<text>Distance maximale du rendu de l'occlusion ambiante.</text>
	</string>

	<string id="ui_mcm_ssfx_module_ao_blur_mcm">
		<text>Flou</text>
	</string>

	<string id="ui_mcm_ssfx_module_ao_blur_mcm_desc">
		<text>Intensité de base du flou pour lisser le résultat de l'occlusion ambiante.</text>
	</string>

	<string id="ui_mcm_ssfx_module_ao_radius_mcm">
		<text>Rayon général</text>
	</string>

	<string id="ui_mcm_ssfx_module_ao_radius_mcm_desc">
		<text>Distance maximale pour tester l'occultation d'un pixel. Il peut être nécessaire d'ajuster l'intensité de l'effet si vous augmentez cette distance.</text>
	</string>

	<string id="ui_mcm_ssfx_module_ao_max_occ_mcm">
		<text>Occlusion maximale</text>
	</string>

	<string id="ui_mcm_ssfx_module_ao_max_occ_mcm_desc">
		<text>Occultation maximale possible d'un pixel. [ 0,0 = noir complet ]</text>
	</string>

	<string id="ui_mcm_ssfx_module_ao_global_int_mcm">
		<text>Intensité globale</text>
	</string>

	<string id="ui_mcm_ssfx_module_ao_global_int_mcm_desc">
		<text>Intensité globale de l'occlusion ambiante. [ 1,0 = 100 % ~ 0,5 = 50 % ]</text>
	</string>

	<string id="ui_mcm_ssfx_module_ao_hud_int_mcm">
		<text>Intensité HUD</text>
	</string>

	<string id="ui_mcm_ssfx_module_ao_hud_int_mcm_desc">
		<text>Intensité des éléments de l'interface (armes, bras, etc.). Il s'agit d'un pourcentage de l'intensité globale. [ 1,0 = 100 % ~ 0,5 = 50 % ]</text>
	</string>

	<string id="ui_mcm_ssfx_module_ao_flora_int_mcm">
		<text>Intensité de la flore</text>
	</string>

	<string id="ui_mcm_ssfx_module_ao_flora_int_mcm_desc">
		<text>Intensité de la flore (herbes, arbres, etc.). Il s'agit d'un pourcentage de l'intensité globale. [ 1,0 = 100 % ~ 0,5 = 50 % ]</text>
	</string>

</string_table>