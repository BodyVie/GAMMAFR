	<string id="ui_mcm_demonized_ledge_grabbing_alternativeClimbDetection">
		<text>Détection alternative d'escalade</text>
	</string>

	<string id="ui_mcm_demonized_ledge_grabbing_alternativeClimbDetection_desc">
		<text>La méthode alternative effectuera un lancer de rayon vers les corniches plus proches du réticule du joueur. La méthode standard effectuera un lancer de rayon depuis une hauteur fixe.</text>
	</string>

	<string id="ui_mcm_demonized_ledge_grabbing_playerWidthCheck">
		<text>Vérification des limites du joueur</text>
	</string>

	<string id="ui_mcm_demonized_ledge_grabbing_playerWidthCheck_desc">
		<text>Si activé, effectuera un lancer de rayon supplémentaire pour vérifier si le joueur tient sur la corniche. Cela pourrait limiter les corniches accessibles pour l'escalade.</text>
	</string>

	<string id="ui_mcm_demonized_ledge_grabbing_unstuckCheck">
		<text>Vérification d'immobilisation</text>
	</string>

	<string id="ui_mcm_demonized_ledge_grabbing_unstuckCheck_desc">
		<text>Si activé, tentera de dégager le joueur si la saisie de la corniche n'a pas été effectuée correctement.</text>
	</string>

	<string id="ui_mcm_demonized_ledge_grabbing_hardcoreMode">
		<text>Mode hardcore</text>
	</string>

	<string id="ui_mcm_demonized_ledge_grabbing_hardcoreMode_desc">
		<text>Lorsqu'activé, ajoute des restrictions supplémentaires pour l'escalade : \n1. Pas d'escalade lorsque le poids du joueur dépasse 90 kg\n2. Pas d'escalade lorsque la santé du joueur est inférieure à 60 %\n3. Augmente l'utilisation de l'endurance.</text>
	</string>

	<string id="ui_mcm_demonized_ledge_grabbing_BHSMode">
		<text>Intégration BHS</text>
	</string>

	<string id="ui_mcm_demonized_ledge_grabbing_BHSMode_desc">
		<text>Lorsqu'activé, si vous utilisez le système de santé corporelle et que l'un des bras du joueur est cassé, il ne sera pas possible de grimper.</text>
	</string>

	<string id="ui_mcm_demonized_ledge_grabbing_throttleCheck">
		<text>Délai de vérification d'escalade</text>
	</string>

	<string id="ui_mcm_demonized_ledge_grabbing_throttleCheck_desc">
		<text>Intervalle entre les vérifications en millisecondes. Augmentez cette valeur pour améliorer les performances au détriment de la précision.</text>
	</string>

	<string id="ui_mcm_demonized_ledge_grabbing_climbTriggerDistance">
		<text>Distance de déclenchement</text>
	</string>
	<string id="ui_mcm_demonized_ledge_grabbing_climbTriggerDistance_desc">
		<text>Distance maximale pour initier la saisie d'une corniche.</text>
	</string>

	<string id="ui_mcm_demonized_ledge_grabbing_raySteps">
		<text>Précision de la saisie de corniche</text>
	</string>
	<string id="ui_mcm_demonized_ledge_grabbing_raySteps_desc">
		<text>Un nombre plus élevé améliore la détection et la position de la saisie au prix d'une légère baisse de performance.</text>
	</string>

	<string id="ui_mcm_demonized_ledge_grabbing_jumpTriggerTime">
		<text>Durée de maintien de la touche</text>
	</string>
	<string id="ui_mcm_demonized_ledge_grabbing_jumpTriggerTime_desc">
		<text>Si vous maintenez la touche plus longtemps que cette durée, la saisie de la corniche sera activée.</text>
	</string>

