<string_table>

	<!-- Button -->
	<string id="ui_mcm_ssfx_module_water">
		<text>Eau</text>
	</string>

	<!-- SSR Settings -->
	<string id="ui_mcm_ssfx_module_water_title">
		<text>Paramètres de l'eau</text>
	</string>

	<string id="ui_mcm_ssfx_module_water_ssr_quality_mcm">
		<text>Qualité SSR</text>
	</string>

	<string id="ui_mcm_ssfx_module_water_ssr_quality_mcm_desc">
		<text>[ REDÉMARRAGE REQUIS ] Nombre d'échantillons utilisés pour le rendu des reflets. Des paramètres plus élevés peuvent fortement impacter vos performances et le temps de chargement initial après avoir effacé le cache des shaders. [ 8, 16, 24, 32, 64 ]</text>
	</string>

	<string id="ui_mcm_ssfx_module_water_ssr_res_mcm">
		<text>Résolution SSR</text>
	</string>

	<string id="ui_mcm_ssfx_module_water_ssr_res_mcm_desc">
		<text>Résolution du rendu SSR. Vous pouvez améliorer les performances en réduisant la résolution. [ 1.0 = 100 % ~ 0.5 = 50 % ]</text>
	</string>

	<string id="ui_mcm_ssfx_module_water_parallax_quality_mcm">
		<text>Qualité de la parallaxe</text>
	</string>

	<string id="ui_mcm_ssfx_module_water_parallax_quality_mcm_desc">
		<text>[ REDÉMARRAGE REQUIS ] Nombre d'échantillons utilisés pour le rendu de l'effet de parallaxe des vagues. Des valeurs plus basses peuvent améliorer les performances. [ 8, 16, 32 ]</text>
	</string>

	<string id="ui_mcm_ssfx_module_water_parallax_height_mcm">
