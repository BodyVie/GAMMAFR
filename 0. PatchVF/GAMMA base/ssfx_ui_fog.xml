<?xml version="1.0" encoding="UTF-8"?>

<string_table>

	<!-- Button -->
	<string id="ui_mcm_ssfx_module_fog">
		<text>Brouillard</text>
	</string>

	<!-- SSR Settings -->
	<string id="ui_mcm_ssfx_module_fog_title">
		<text>Paramètres du brouillard</text>
	</string>

	<string id="ui_mcm_ssfx_module_fog_height_mcm">
		<text>Hauteur</text>
	</string>

	<string id="ui_mcm_ssfx_module_fog_height_mcm_desc">
		<text>Ajuste la hauteur du brouillard. Plus la valeur est élevée, plus le brouillard est uniforme.</text>
	</string>

	<string id="ui_mcm_ssfx_module_fog_density_mcm">
		<text>Densité</text>
	</string>

	<string id="ui_mcm_ssfx_module_fog_density_mcm_desc">
		<text>Densité globale du brouillard en hauteur. La valeur de base reste gérée par les préréglages météorologiques.</text>
	</string>

	<string id="ui_mcm_ssfx_module_fog_suncolor_mcm">
		<text>Teinte du soleil</text>
	</string>

	<string id="ui_mcm_ssfx_module_fog_suncolor_mcm_desc">
		<text>Option permettant de régler la proportion de la couleur du soleil utilisée pour teinter le brouillard.</text>
	</string>


	<string id="ui_mcm_ssfx_module_fog_scattering_mcm">
		<text>Diffusion du brouillard</text>
	</string>

	<string id="ui_mcm_ssfx_module_fog_scattering_mcm_desc">
		<text>Intensité de l'effet de diffusion du brouillard. Cet effet renforce la sensation de densité du brouillard.</text>
	</string>


