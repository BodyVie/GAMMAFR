	<string id="ui_mcm_ssfx_module_shadows_title">
		<text>Paramètres ombres et lumière</text>
	</string>

	<string id="ui_mcm_ssfx_module_shadows_lod_quality_mcm">
		<text>Niveau de détail des ombres</text>
	</string>

	<string id="ui_mcm_ssfx_module_shadows_lod_quality_mcm_desc">
		<text>Qualité de base de la carte d'ombres. Plus la valeur est élevée, plus la résolution de base des ombres et leur résolution à distance sont élevées.</text>
	</string>

	<string id="ui_mcm_ssfx_module_shadows_lod_min_mcm">
		<text>Résolution min. des ombres</text>
	</string>

	<string id="ui_mcm_ssfx_module_shadows_lod_min_mcm_desc">
		<text>Résolution minimale de la carte d'ombres. Lorsque les sources de lumière sont éloignées du joueur, la résolution des ombres diminue pour améliorer les performances (au détriment de la qualité d'image).</text>
	</string>

	<string id="ui_mcm_ssfx_module_shadows_lod_max_mcm">
		<text>Résolution max. des ombres</text>
	</string>

	<string id="ui_mcm_ssfx_module_shadows_lod_max_mcm_desc">
		<text>Résolution maximale de la carte d'ombres. Lorsque les sources de lumière sont proches, la résolution augmente pour améliorer la qualité des ombres (au détriment des performances).</text>
	</string>

	<string id="ui_mcm_ssfx_module_shadows_volumetric_force_mcm">
		<text>Forcer le volumétrique (rechargement de la carte requis)</text>
	</string>

	<string id="ui_mcm_ssfx_module_shadows_volumetric_force_mcm_desc">
		<text>Force l'effet volumétrique sur toutes les sources de lumière non directionnelles. Vous devez recharger la carte pour appliquer ce paramètre.</text>
	</string>

	<string id="ui_mcm_ssfx_module_shadows_volumetric_int_mcm">
		<text>Intensité volumétrique</text>
	</string>

	<string id="ui_mcm_ssfx_module_shadows_volumetric_resolution_mcm">
		<text>Résolution volumétrique</text>
	</string>

	<string id="ui_mcm_ssfx_module_shadows_volumetric_resolution_mcm_desc">
		<text>Résolution du rendu volumétrique. Pourcentage de votre résolution actuelle. [ min : 14 % ~ max : 100 % ]</text>
	</string>

	<string id="ui_mcm_ssfx_module_shadows_volumetric_int_mcm_desc">
		<text>Règle l'intensité de l'effet volumétrique.</text>
	</string>

	<string id="ui_mcm_ssfx_module_shadows_volumetric_quality_mcm">
		<text>Qualité volumétrique</text>
	</string>

	<string id="ui_mcm_ssfx_module_shadows_volumetric_quality_mcm_desc">
		<text>Définit la qualité de l'effet volumétrique au détriment des performances.</text>
