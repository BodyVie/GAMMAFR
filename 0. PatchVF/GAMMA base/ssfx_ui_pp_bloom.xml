<?xml version="1.0" encoding="UTF-8"?>


<string_table>

	<!-- Bloom Title -->
	<string id="ui_mcm_ssfx_module_bloom_title">
		<text>Bloom - Paramètres</text>
	</string>

	<!-- Bloom Settings -->
	<string id="ui_mcm_ssfx_module_ssfx_pp_ssfx_bloom_use_weather_mcm">
		<text>Utiliser les préréglages météo</text>
	</string>

	<string id="ui_mcm_ssfx_module_ssfx_pp_ssfx_bloom_use_weather_mcm_desc">
		<text>Remplace les valeurs de `Seuil`, `Exposition` et `Intensité du ciel` par celles définies dans les préréglages météorologiques.</text>
	</string>

	<string id="ui_mcm_ssfx_module_ssfx_pp_ssfx_bloom_threshold_mcm">
		<text>Seuil</text>
	</string>

	<string id="ui_mcm_ssfx_module_ssfx_pp_ssfx_bloom_threshold_mcm_desc">
		<text>Définissez la luminosité minimale qu'un pixel doit avoir pour produire un effet bloom. [ 1.0 = Tous les pixels produisent un bloom ]</text>
	</string>

	<string id="ui_mcm_ssfx_module_ssfx_pp_ssfx_bloom_exposure_mcm">
		<text>Exposition</text>
	</string>

	<string id="ui_mcm_ssfx_module_ssfx_pp_ssfx_bloom_exposure_mcm_desc">
		<text>Augmente ou diminue l'intensité du bloom.</text>
	</string>

	<string id="ui_mcm_ssfx_module_ssfx_pp_ssfx_bloom_blur_mcm">
		<text>Rayon de flou</text>
	</string>

	<string id="ui_mcm_ssfx_module_ssfx_pp_ssfx_bloom_blur_mcm_desc">
		<text>Cette valeur définit l'étendue de la diffusion de l'effet bloom.</text>
	</string>

	<string id="ui_mcm_ssfx_module_ssfx_pp_ssfx_bloom_vibrance_mcm">
		<text>Vivacité</text>
	</string>

	<string id="ui_mcm_ssfx_module_ssfx_pp_ssfx_bloom_vibrance_mcm_desc">
		<text>Ajustez la vivacité des couleurs du bloom. [ 0.0 = Niveaux de gris ~ 1.0 = Couleur ]</text>
	</string>

	<string id="ui_mcm_ssfx_module_ssfx_pp_ssfx_bloom_sky_mcm">
		<text>Intensité du ciel</text>
	</string>

	<string id="ui_mcm_ssfx_module_ssfx_pp_ssfx_bloom_sky_mcm_desc">
		<text>Utilisez cette valeur pour configurer l'intensité du ciel.</text>
	</string>


	<string id="ui_mcm_ssfx_module_ssfx_pp_ssfx_bloom_lens_mcm">
		<text>Intensité des reflets</text>
	</string>

	<string id="ui_mcm_ssfx_module_ssfx_pp_ssfx_bloom_lens_mcm_desc">
		<text>Ajustez l'intensité de l'effet de lens flare lorsque vous utilisez un masque à gaz.</text>
	</string>

	<string id="ui_mcm_ssfx_module_ssfx_pp_ssfx_bloom_dirt_mcm">
		<text>Intensité des salissures</text>
	</string>

	<string id="ui_mcm_ssfx_module_ssfx_pp_ssfx_bloom_dirt_mcm_desc">
		<text>Ajustez l'intensité de l'effet de saleté lorsque vous utilisez un masque à gaz.</text>
	</string>

</string_table>