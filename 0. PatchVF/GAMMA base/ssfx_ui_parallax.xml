<?xml version="1.0" encoding="UTF-8"?>

<string_table>

	<!-- Button -->
	<string id="ui_mcm_ssfx_module_parallax">
		<text>Parallaxe</text>
	</string>

	<!-- Parallax Settings -->
	<string id="ui_mcm_ssfx_module_parallax_title">
		<text>Paramètres du terrain</text>
	</string>

	<string id="ui_mcm_ssfx_module_parallax_quality_mcm">
		<text>Qualité de la parallaxe</text>
	</string>

	<string id="ui_mcm_ssfx_module_parallax_quality_mcm_desc">
		<text>Définissez la qualité visuelle de l'effet. Des paramètres plus élevés augmentent le nombre d'échantillons utilisés pour lisser le résultat.</text>
	</string>

	<string id="ui_mcm_ssfx_module_parallax_refine_mcm">
		<text>Affinement de parallaxe</text>
	</string>

	<string id="ui_mcm_ssfx_module_parallax_refine_mcm_desc">
		<text>Ajoute une phase de raffinement pour améliorer l'effet de parallaxe. Activez ou désactivez cette option pour améliorer la qualité visuelle ou gagner en performance.</text>
	</string>

	<string id="ui_mcm_ssfx_module_parallax_range_mcm">
		<text>Distance de parallaxe</text>
	</string>

	<string id="ui_mcm_ssfx_module_parallax_range_mcm_desc">
		<text>Option permettant de définir la distance maximale de rendu de l'effet de parallaxe.</text>
	</string>

	<string id="ui_mcm_ssfx_module_parallax_height_mcm">
		<text>Hauteur de parallaxe</text>
	</string>

	<string id="ui_mcm_ssfx_module_parallax_height_mcm_desc">
		<text>Utilisez cette valeur pour ajuster la hauteur maximale de l'effet de parallaxe.</text>
	</string>

	<string id="ui_mcm_ssfx_module_parallax_ao_mcm">
		<text>Occlusion ambiante de parallaxe</text>
	</string>

	<string id="ui_mcm_ssfx_module_parallax_ao_mcm_desc">
		<text>Définit la quantité supplémentaire d'occlusion ambiante appliquée aux surfaces en parallaxe.</text>
	</string>

</string_table>