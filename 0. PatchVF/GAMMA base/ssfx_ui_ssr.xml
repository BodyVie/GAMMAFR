<?xml version="1.0" encoding="UTF-8"?>

<string_table>

	<!-- Button -->
	<string id="ui_mcm_ssfx_module_ssr">
		<text>SSR</text>
	</string>

	<!-- SSR Settings -->
	<string id="ui_mcm_ssfx_module_ssr_title">
		<text>Paramètres des réflexions</text>
	</string>

	<string id="ui_mcm_ssfx_module_ssr_quality_mcm">
		<text>Qualité (étapes)</text>
	</string>

	<string id="ui_mcm_ssfx_module_ssr_quality_mcm_desc">
		<text>[ REDÉMARRAGE REQUIS ] Nombre d'étapes utilisées pour le rendu des reflets. Cette option peut avoir un impact significatif sur les performances. [ 8, 16, 24, 32, 48, 64 ]</text>
	</string>

	<string id="ui_mcm_ssfx_module_ssr_render_scale_mcm">
		<text>Échelle de rendu</text>
	</string>

	<string id="ui_mcm_ssfx_module_ssr_render_scale_mcm_desc">
		<text>Échelle de rendu du SSR. Cette option diminue la qualité visuelle de l'effet, mais améliore les performances. Si vous réduisez l'échelle de rendu, envisagez d'augmenter l'intensité du flou pour masquer la baisse de qualité du SSR.</text>
	</string>

	<string id="ui_mcm_ssfx_module_ssr_blur_mcm">
		<text>Flou</text>
	</string>

	<string id="ui_mcm_ssfx_module_ssr_blur_mcm_desc">
		<text>Option permettant de définir le niveau de flou des reflets.</text>
	</string>

	<string id="ui_mcm_ssfx_module_ssr_temporal_mcm">
		<text>Accumulation temporelle</text>
	</string>

	<string id="ui_mcm_ssfx_module_ssr_temporal_mcm_desc">
		<text>Quantité d'images précédentes utilisée pour stabiliser les reflets. Cette option réduit le bruit et améliore généralement le résultat du SSR, mais des valeurs plus élevées peuvent générer des effets de rémanence.</text>
	</string>

	<string id="ui_mcm_ssfx_module_ssr_use_noise_mcm">
		<text>Bruit</text>
	</string>

	<string id="ui_mcm_ssfx_module_ssr_use_noise_mcm_desc">
		<text>Active/désactive le bruit pour améliorer la reconstruction du SSR. Il est recommandé d'utiliser cette option avec des valeurs de flou élevées.</text>
	</string>

	<string id="ui_mcm_ssfx_module_ssr_general_int_mcm">
		<text>Intensité générale</text>
	</string>

	<string id="ui_mcm_ssfx_module_ssr_general_int_mcm_desc">
		<text>Intensité générale des reflets.</text>
	</string>

	<string id="ui_mcm_ssfx_module_ssr_sky_int_mcm">
		<text>Intensité du ciel</text>
	</string>

	<string id="ui_mcm_ssfx_module_ssr_sky_int_mcm_desc">
		<text>Intensité de la réflexion du ciel.</text>
	</string>

	<string id="ui_mcm_ssfx_module_ssr_weapon_int_mcm">
		<text>Intensité des armes</text>
	</string>

	<string id="ui_mcm_ssfx_module_ssr_weapon_int_mcm_desc">
		<text>Intensité des reflets sur les armes.</text>
	</string>

	<string id="ui_mcm_ssfx_module_ssr_weapon_int_max_mcm">
		<text>Intensité maximale des armes</text>
	</string>

	<string id="ui_mcm_ssfx_module_ssr_weapon_int_max_mcm_desc">
		<text>Intensité maximale des reflets sur les armes.</text>
	</string>


</string_table>