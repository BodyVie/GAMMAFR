	</string>
	<string id="ui_mcm_targetID_flipAlign_desc">
		<text>Le nom et le grade seront alignés à droite afin de permettre le placement de l'interface HUD sur le côté droit de l'écran.</text>
	</string>
	
	<string id="ui_mcm_targetID_colorR">
