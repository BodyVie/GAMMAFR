	</string>

	<string id="ui_mcm_targetID_timeID">
		<text>Retarder l'identification par la distance</text>
	</string>
	<string id="ui_mcm_targetID_timeID_desc">
		<text>Si cette option est activée, l'identification nécessitera de fixer un stalker pendant une durée déterminée par la distance pour l'identifier.</text>
	</string>

	<string id="ui_mcm_targetID_rankID">
		<text>Identifier le grade du stalker</text>
	</string>

	<string id="ui_mcm_targetID_talkName">
		<text>Apprentissage du nom requis</text>
	</string>
	<string id="ui_mcm_targetID_talkName_desc">
		<text>Si cette option est activée, le joueur doit parler à un stalker ou le fouiller pour connaître son nom et son grade.</text>
	</string>

	<string id="ui_mcm_targetID_speedID">
		<text>Vitesse d'identification</text>
	</string>
	
